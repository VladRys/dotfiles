{
  "layer": "top",
  "position": "top",
  "height": 32,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["clock"],
  "modules-right": ["mpris", "cpu", "memory", "network", "pulseaudio", "battery"],

  "mpris":{
    "format": "  {artist} - {title}",
    "format-paused": "  {artist} - {title}",
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
    "interval": 1  
  },

  "clock": {
    "format": "  {:%H:%M}",
    "tooltip": true,
    "format-alt": "{:%A, %d %B %Y}"
  },

  "cpu": {
    "format": "  {usage}%",
    "interval": 2
  },

  "memory": {
    "format": "  {}%",
    "interval": 5
  },

  "network": {
    "format-wifi": "  {essid}",
    "format-ethernet": "󰈀  Connected",
    "format-disconnected": "  Offline"
  },

  "pulseaudio": {
    "format": "  {volume}%",
    "format-muted": "  muted"
  },

  "battery": {
    "format": "  {capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    }
  }
}
